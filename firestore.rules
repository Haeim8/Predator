rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Incidents ──
    match /incidents/{incidentId} {
      // Public: verified only. Journalists: all statuses.
      allow read: if resource.data.status == 1
                  || (request.auth != null
                      && exists(/databases/$(database)/documents/journalists/$(request.auth.uid)));

      // Authenticated users can create with status forced to 0 (pending)
      allow create: if request.auth != null
                    && request.resource.data.status == 0
                    && request.resource.data.keys().hasAll(['description', 'latitude', 'longitude', 'type', 'status', 'createdAt']);

      // Only journalists can update
      allow update: if request.auth != null
                    && exists(/databases/$(database)/documents/journalists/$(request.auth.uid));
    }

    // ── Convicted Persons ──
    match /convicted_persons/{personId} {
      // Public: verified only. Journalists: all statuses.
      allow read: if resource.data.status == 1
                  || (request.auth != null
                      && exists(/databases/$(database)/documents/journalists/$(request.auth.uid)));

      // Authenticated users can create with status forced to 0 (pending)
      allow create: if request.auth != null
                    && request.resource.data.status == 0
                    && request.resource.data.keys().hasAll(['firstName', 'lastName', 'facts', 'status', 'createdAt']);

      // Only journalists can update
      allow update: if request.auth != null
                    && exists(/databases/$(database)/documents/journalists/$(request.auth.uid));
    }

    // ── Journalists ──
    match /journalists/{journalistId} {
      // Read/write only by the owner
      allow read, write: if request.auth != null && request.auth.uid == journalistId;
    }
  }
}
